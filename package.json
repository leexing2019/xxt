{
  "name": "AI用药助手",
  "version": "1.0.0",
  "description": "专为老年人设计的智能用药管理APP",
  "main": "index.js",
  "scripts": {
    "dev:h5": "uni",
    "build:h5": "uni build",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin",
    "dev:app": "uni -p app",
    "build:app": "uni build -p app",
    "dev:app-android": "uni -p app-android",
    "build:app-android": "uni build -p app-android"
  },
  "keywords": [
    "medication",
    "elderly",
    "AI",
    "health"
  ],
  "author": "Matrix Agent",
  "license": "MIT",
  "uni-app": {
    "name": "AI用药助手",
    "appid": "__UNI__MEDICATION",
    "description": "专为老年人设计的智能用药管理APP",
    "versionName": "1.0.0",
    "versionCode": "100",
    "transformPx": false,
    "app-plus": {
      "usingComponents": true,
      "nvueStyleCompiler": "uni-app",
      "compilerVersion": 3,
      "splashscreen": {
        "alwaysShowBeforeRender": true,
        "waiting": true,
        "autoclose": true,
        "delay": 0
      },
      "modules": {},
      "distribute": {
        "android": {
          "permissions": [
            "<uses-permission android:name=\"android.permission.CAMERA\"/>",
            "<uses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/>",
            "<uses-permission android:name=\"android.permission.WRITE_EXTERNAL_STORAGE\"/>",
            "<uses-permission android:name=\"android.permission.CALL_PHONE\"/>",
            "<uses-permission android:name=\"android.permission.RECORD_AUDIO\"/>",
            "<uses-permission android:name=\"android.permission.VIBRATE\"/>",
            "<uses-permission android:name=\"android.permission.RECEIVE_BOOT_COMPLETED\"/>",
            "<uses-permission android:name=\"android.permission.SEND_SMS\"/>",
            "<uses-permission android:name=\"android.permission.READ_PHONE_STATE\"/>",
            "<uses-permission android:name=\"android.permission.ACCESS_FINE_LOCATION\"/>",
            "<uses-permission android:name=\"android.permission.ACCESS_COARSE_LOCATION\"/>"
          ],
          "minSdkVersion": 21,
          "targetSdkVersion": 30
        },
        "sdkConfigs": {}
      }
    },
    "quickapp": {},
    "mp-weixin": {
      "appid": "",
      "setting": {
        "urlCheck": false,
        "es6": true,
        "minified": true
      },
      "usingComponents": true
    },
    "mp-alipay": {
      "usingComponents": true
    },
    "mp-baidu": {
      "usingComponents": true
    },
    "mp-toutiao": {
      "usingComponents": true
    },
    "uniStatistics": {
      "enable": false
    },
    "h5": {
      "title": "AI用药助手",
      "router": {
        "mode": "hash"
      }
    }
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4010520240507001",
    "@dcloudio/uni-app-plus": "3.0.0-4010520240507001",
    "@dcloudio/uni-components": "3.0.0-4010520240507001",
    "@dcloudio/uni-h5": "3.0.0-4010520240507001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4010520240507001",
    "@supabase/supabase-js": "^2.39.0",
    "pinia": "^2.1.7",
    "pinyin-match": "^1.2.10",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4010520240507001",
    "@dcloudio/uni-cli-shared": "3.0.0-4010520240507001",
    "@dcloudio/uni-stacktracey": "3.0.0-4010520240507001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4010520240507001",
    "@playwright/test": "^1.58.2",
    "playwright-core": "^1.58.2",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.8"
  }
}
